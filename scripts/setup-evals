#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"

ensure_python() {
	if command -v python3 >/dev/null 2>&1; then
		printf '%s\n' "python3"
		return 0
	fi

	echo "未找到可用的 python3，无法初始化评估 workspace。" >&2
	exit 1
}

PYTHON_BIN="$(ensure_python)"
PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON_BIN" -m weibo_cli.eval_setup "$@"
