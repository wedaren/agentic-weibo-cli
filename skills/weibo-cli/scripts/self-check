#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
CLI="$SCRIPT_DIR/weibo-cli"

echo "[1/4] 校验 skills 元数据"
"$CLI" skills validate

echo "[2/4] 检查 CLI 帮助"
"$CLI" --help >/dev/null

echo "[3/4] 检查浏览器自动化"
"$CLI" login --check-browser >/dev/null

echo "[4/4] 验证当前登录态可读"
"$CLI" list --limit 1 --page 1 >/dev/null

echo "自检通过：skills、帮助、浏览器自动化和最近微博读取均正常。"