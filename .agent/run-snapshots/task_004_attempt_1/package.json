{
  "name": "agentic-weibo-cli",
  "version": "0.1.0",
  "description": "Personal Weibo CLI for local single-user workflows.",
  "private": true,
  "bin": {
    "weibo-cli": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "npm run build --silent && node dist/bin/cli.js",
    "help": "npm run cli -- --help"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3"
  }
}
