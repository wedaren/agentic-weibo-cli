#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
SKILL_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
VENV_DIR="$SKILL_DIR/.venv"
VENV_PYTHON="$VENV_DIR/bin/python3"
REQUIREMENTS_FILE="$SKILL_DIR/requirements.txt"

ensure_python() {
	if command -v python3 >/dev/null 2>&1; then
		printf '%s\n' "python3"
		return 0
	fi

	echo "未找到可用的 python3，无法启动 weibo-cli。" >&2
	exit 1
}

ensure_venv_ready() {
	if [[ -x "$VENV_PYTHON" ]]; then
		if "$VENV_PYTHON" -c 'import requests, playwright' >/dev/null 2>&1; then
			return 0
		fi
	fi

	local system_python
	system_python="$(ensure_python)"

	echo "初始化 weibo-cli 运行环境..." >&2
	"$system_python" -m venv "$VENV_DIR"
	"$VENV_PYTHON" -m pip install --upgrade pip >/dev/null
	"$VENV_PYTHON" -m pip install -r "$REQUIREMENTS_FILE" >/dev/null
}

ensure_venv_ready
PYTHON_BIN="$VENV_PYTHON"

PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON_BIN" -m weibo_cli.cli "$@"