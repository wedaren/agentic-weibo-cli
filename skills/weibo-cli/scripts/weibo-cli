#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/../.venv/bin/python3"

if [[ -x "$VENV_PYTHON" ]]; then
	PYTHON_BIN="$VENV_PYTHON"
else
	PYTHON_BIN="python3"
fi

PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON_BIN" -m weibo_cli.cli "$@"